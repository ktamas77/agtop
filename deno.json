{
  "name": "@ktamas77/agentop",
  "version": "0.5.2",
  "exports": "./main.ts",
  "tasks": {
    "start": "deno run -A main.ts",
    "demo": "deno run -A main.ts --demo",
    "test": "deno test -A",
    "check": "deno fmt --check && deno lint && deno check main.ts && deno test -A"
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": true,
    "exclude": [
      "dist",
      "docs",
      "node_modules",
      "CHANGELOG.md",
      "README.md"
    ]
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any"
      ]
    },
    "exclude": [
      "dist",
      "node_modules"
    ]
  },
  "exclude": [
    "dist",
    "node_modules",
    "docs"
  ],
  "publish": {
    "include": [
      "main.ts",
      "src",
      "README.md",
      "LICENSE",
      "deno.json"
    ]
  }
}
